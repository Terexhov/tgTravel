TG_BOT_TOKEN=your_telegram_bot_token

# Aviasales / TravelPayouts (flights)
AVIASALES_TOKEN=your_travelpayouts_api_token
AVIASALES_MARKER=your_partner_marker_id

# Flight deeplink base — can be replaced with Yandex: https://yandex.tpx.li/47l6z11e
PARTNER_URL_BASE=https://www.aviasales.ru/search

# TravelPayouts hotel affiliate deeplink
# Format: https://tp.media/r?marker=M&trs=T&p=P&u=URL
# Set all three to enable affiliate wrapping on hotel links
TP_TRS=your_tracking_source_id
TP_HOTEL_PROGRAM=your_yandex_hotels_program_id

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5

# Redis (required for FSM persistence + rate limiting)
REDIS_URL=redis://localhost:6379/0

# Rate limits
RATE_MSG_PER_MIN=30
RATE_LLM_PER_HOUR=10

# Admin metrics command
ADMIN_ID=your_telegram_user_id

# Metrics DB path
METRICS_DB=metrics.db
